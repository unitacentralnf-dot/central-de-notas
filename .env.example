# Configurações do Supabase
VITE_SUPABASE_URL=sua_url_do_supabase_aqui
VITE_SUPABASE_ANON_KEY=sua_chave_anon_do_supabase_aqui

# Chave service_role do Supabase (necessária para criar usuários via Auth Admin)
# Encontre em: Project Settings → API → service_role secret
# VITE_SUPABASE_SERVICE_KEY=sua_chave_service_role_aqui

# Provedor de dados: 'mock' (padrão) ou 'real' (para APIs externas)
# VITE_DATA_PROVIDER=mock

# Credenciais das APIs reais (usadas apenas quando VITE_DATA_PROVIDER=real)
# VITE_FOCUSNFE_TOKEN=seu_token_aqui
# VITE_FOCUSNFE_URL=https://homologacao.focusnfe.com.br/v2
# VITE_PLUGOCR_TOKEN=seu_token_aqui
# VITE_ASAAS_TOKEN=seu_token_aqui
# VITE_ASAAS_URL=https://sandbox.asaas.com/api/v3
