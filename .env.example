# .env.example
# Copie este arquivo para .env e preencha as variáveis com as chaves reais.

VITE_SUPABASE_URL=https://<YOUR_PROJECT>.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_SUPABASE_SERVICE_KEY=YOUR_SERVICE_KEY

# Provedor de dados: 'mock' (padrão) ou 'real' (para APIs externas)
VITE_DATA_PROVIDER=mock

# Credenciais das APIs externas (usar quando VITE_DATA_PROVIDER=real)
VITE_FOCUS_API_KEY=YOUR_FOCUS_API_KEY   # Focus NFe
VITE_CELCOIN_API_KEY=YOUR_CELCOIN_API_KEY   # Celcoin DDA
VITE_CENPROT_API_KEY=YOUR_CENPROT_API_KEY   # Cenprot protestos
VITE_GCP_VISION_KEY=YOUR_GCP_VISION_KEY   # OCR (Google Vision)
